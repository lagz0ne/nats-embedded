{
  "name": "@lagz0ne/nats-embedded",
  "version": "0.3.1",
  "description": "Embedded NATS server for Node.js and Bun — managed child process with random port allocation",
  "type": "module",
  "license": "Apache-2.0",
  "author": "lagz0ne",
  "repository": {
    "type": "git",
    "url": "https://github.com/lagz0ne/nats-embedded",
    "directory": "packages/nats-embedded"
  },
  "homepage": "https://github.com/lagz0ne/nats-embedded",
  "bugs": "https://github.com/lagz0ne/nats-embedded/issues",
  "keywords": ["nats", "embedded", "messaging", "testing", "pubsub", "jetstream"],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "LICENSE"],
  "scripts": {
    "build": "tsdown",
    "test": "bun test"
  },
  "optionalDependencies": {
    "@lagz0ne/nats-embedded-linux-x64": "0.3.1",
    "@lagz0ne/nats-embedded-linux-arm64": "0.3.1",
    "@lagz0ne/nats-embedded-darwin-x64": "0.3.1",
    "@lagz0ne/nats-embedded-darwin-arm64": "0.3.1",
    "@lagz0ne/nats-embedded-win32-x64": "0.3.1",
    "@lagz0ne/nats-embedded-win32-arm64": "0.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.2.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.7.0"
  }
}
